<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="google-site-verification" content="JWxwS1t6gyy_0zwxd62NkA6-3Xr2wYivugBjHmutQJQ" />
  <meta name="description" content="{{ description or 'DIY Tesla repair guides, tutorials, and tool recommendations from an independent Tesla mechanic. Save money on repairs with our step-by-step guides.' }}">
  <meta name="author" content="TeslaDIYRepair">
  <link rel="canonical" href="https://tesladiyrepair.com{{ page.url }}">

  <!-- Open Graph / Social -->
  <meta property="og:type" content="{% if layout == 'post.njk' %}article{% else %}website{% endif %}">
  <meta property="og:title" content="{{ title }} | Tesla DIY Repair">
  <meta property="og:description" content="{{ description or 'Expert Tesla repair guides from an independent mechanic' }}">
  <meta property="og:url" content="https://tesladiyrepair.com{{ page.url }}">
  <meta property="og:site_name" content="Tesla DIY Repair">
  <meta property="og:image" content="https://tesladiyrepair.com{{ featuredImage or '/images/social-share.jpg' }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }} | Tesla DIY Repair">
  <meta name="twitter:description" content="{{ description or 'Expert Tesla repair guides from an independent mechanic' }}">
  <meta name="twitter:image" content="https://tesladiyrepair.com{{ featuredImage or '/images/social-share.jpg' }}">

  <title>{{ title }} | Tesla DIY Repair</title>

  <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="alternate" type="application/rss+xml" title="Tesla DIY Repair RSS Feed" href="/feed.xml">
  <link rel="sitemap" type="application/xml" href="/sitemap.xml">

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-MHWB6T22RQ"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-MHWB6T22RQ');
  </script>

  <!-- Geo-detect via Cloudflare /cdn-cgi/trace — routes visitors to their local Amazon marketplace -->
  <script>
    (function() {
      var US_MARKET = ['US','CA','MX','PR'];
      var DE_MARKET = ['DE','AT','CH','NL','BE','FR','IT','ES','LU','PL','CZ','SK','HU','SI','DK','SE','FI','NO','IE','GB','PT','GR','EE','LV','LT','HR','BG','RO','MT','CY','IS'];
      var SG_MARKET = ['SG'];
      var UNSUPPORTED = ['CN','HK','TW','IN','JP','KR','TH','VN','MY','PH','ID','AU','NZ','ZA','BR','AR','AE','SA','EG','TR','RU','UA','IL'];
      fetch('/cdn-cgi/trace', { cache: 'no-store' })
        .then(function(r) { return r.text(); })
        .then(function(text) {
          var m = text.match(/^loc=(.+)$/m);
          var c = (m && m[1]) ? m[1].trim().toUpperCase() : 'XX';
          var market = 'unknown';
          if (US_MARKET.indexOf(c) !== -1) market = 'us';
          else if (DE_MARKET.indexOf(c) !== -1) market = 'de';
          else if (SG_MARKET.indexOf(c) !== -1) market = 'sg';
          else if (UNSUPPORTED.indexOf(c) !== -1) market = 'unsupported';
          document.documentElement.setAttribute('data-market', market);
          document.documentElement.setAttribute('data-country', c);
          // Send to GA4 so we can see market distribution in reports
          if (typeof gtag === 'function') {
            gtag('set', 'user_properties', { market: market, country: c });
          }
        })
        .catch(function() {
          document.documentElement.setAttribute('data-market', 'unknown');
        });
    })();
  </script>
  <style>
    /* Default (no data-market or data-market="unknown"): US + DE Amazon buttons visible, SG buttons hidden.
       Geo-detect swaps marketplaces once CDN trace resolves (~20-50ms). */
    html[data-market="us"] .btn-amazon-de { display: none !important; }
    html[data-market="de"] .btn-amazon-us { display: none !important; }
    /* SG market: hide US/DE Amazon (user can't buy), show Lazada + Shopee instead */
    html[data-market="sg"] .btn-amazon-us,
    html[data-market="sg"] .btn-amazon-de { display: none !important; }
    /* Lazada/Shopee SG buttons: hidden everywhere except SG (default-hidden to avoid flash on US/DE) */
    html:not([data-market="sg"]) .btn-lazada-sg,
    html:not([data-market="sg"]) .btn-shopee-sg { display: none !important; }
    /* Unsupported regions (CN, etc.): hide all marketplace buttons — keeps Payhip/newsletter focus */
    html[data-market="unsupported"] .btn-amazon-us,
    html[data-market="unsupported"] .btn-amazon-de { display: none !important; }
  </style>

  <!-- Google AdSense placeholder - replace ca-pub-YOURCODE with your AdSense publisher ID -->
  <!-- <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-YOURCODE" crossorigin="anonymous"></script> -->
</head>
<body>
  <a href="#main-content" class="skip-nav">Skip to main content</a>
  <header class="site-header">
    <nav class="nav-container">
      <a href="/" class="logo">
        <span class="logo-icon">⚡</span>
        <span class="logo-text">Tesla DIY Repair</span>
      </a>
      <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
        <span class="hamburger"></span>
      </button>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/guides/">Repair Guides</a></li>
        <li><a href="/news/">News</a></li>
        <li><a href="/tools/">Recommended Tools</a></li>
        <li><a href="/search/">Search</a></li>
        <li><a href="/about/">About</a></li>
      </ul>
    </nav>
  </header>

  <main class="main-content" id="main-content">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="footer-content">
      <div class="footer-section">
        <h3>Tesla DIY Repair</h3>
        <p>Independent Tesla repair guides from a self-taught mechanic. Save thousands on repairs by doing it yourself.</p>
      </div>
      <div class="footer-section">
        <h3>Popular Guides</h3>
        <ul>
          <li><a href="/posts/tesla-brake-pad-replacement/">Brake Pad Replacement</a></li>
          <li><a href="/posts/tesla-12v-battery-replacement/">12V Battery Replacement</a></li>
          <li><a href="/posts/tesla-cabin-air-filter/">Cabin Air Filter Change</a></li>
        </ul>
      </div>
      <div class="footer-section">
        <h3>Quick Links</h3>
        <ul>
          <li><a href="/guides/">All Repair Guides</a></li>
          <li><a href="/tools/">Recommended Tools</a></li>
          <li><a href="/search/">Search</a></li>
          <li><a href="/about/">About</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 Tesla DIY Repair. Not affiliated with Tesla, Inc.</p>
    </div>
  </footer>

  <script>
    // Mobile navigation toggle
    const navToggle = document.querySelector('.nav-toggle');
    const navLinks = document.querySelector('.nav-links');

    navToggle.addEventListener('click', () => {
      const isOpen = navLinks.classList.toggle('nav-open');
      navToggle.classList.toggle('nav-open');
      navToggle.setAttribute('aria-expanded', isOpen);
    });

    // Close menu when clicking a link
    navLinks.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        navLinks.classList.remove('nav-open');
        navToggle.classList.remove('nav-open');
        navToggle.setAttribute('aria-expanded', 'false');
      });
    });
  </script>
</body>
</html>
