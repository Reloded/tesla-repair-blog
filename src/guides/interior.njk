<div class="posts-grid">
  {% for post in collections.posts | reverse %}
    {% set cat = post.data.category | lower %}
    {% if cat == "interior" %}
    <article class="post-card">
      <div class="post-card-visual cat-interior">
        <span class="cat-icon">🪑</span>
        <span class="difficulty-tag">{{ post.data.difficulty or "Easy" }}</span>
        <span class="cat-label">{{ post.data.category }}</span>
      </div>
      <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
      <p class="post-excerpt">{{ post.data.description }}</p>
    </article>
    {% endif %}
  {% endfor %}
</div>
