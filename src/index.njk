  <form class="hero-search" action="/search/" method="get" role="search">
    <label for="hero-q" class="sr-only">Search repair guides</label>
    <input type="search" id="hero-q" name="q" placeholder="Search guides — e.g. brake pads, 12V battery, AC filter..." autocomplete="off">
    <button type="submit" aria-label="Search">🔍</button>
  </form>
  <a href="/guides/" class="hero-cta">Browse All Guides</a>
</div>

<section>
  <div class="section-header">
    <h2>Latest Repair Guides</h2>
    <p>Step-by-step tutorials to fix your Tesla yourself</p>
  </div>

  <div class="posts-grid">
    {% for post in collections.repairGuides %}
    {% if loop.index <= 6 %}
    {% set category = post.data.category | lower %}
    {% set filterGroup = "other" %}
    {% if category == "electrical" or category == "battery" or category == "connectivity" %}
      {% set filterGroup = "electrical" %}
    {% elif category == "software" or category == "troubleshooting" or category == "autopilot" or category == "autopilot & safety" or category == "features" or category == "cameras" %}
      {% set filterGroup = "software" %}
    {% elif category == "maintenance" or category == "tires" or category == "wheels" or category == "driving" %}
      {% set filterGroup = "maintenance" %}
    {% elif category == "interior" %}
      {% set filterGroup = "interior" %}
    {% elif category == "suspension" or category == "brakes" %}
      {% set filterGroup = "suspension" %}
    {% elif category == "hvac" or category == "climate" %}
      {% set filterGroup = "hvac" %}
    {% elif category == "exterior" or category == "body" or category == "body & exterior" or category == "body & glass" %}
      {% set filterGroup = "exterior" %}
    {% elif category == "charging" %}
      {% set filterGroup = "charging" %}
    {% endif %}
    <article class="post-card">
      <div class="post-card-visual cat-{{ filterGroup }}">
        <span class="cat-icon">{{ icon(filterGroup) }}</span>
      </div>
      <div class="post-card-content">
        <span class="post-card-category">{{ post.data.category or "Repair Guide" }}</span>
        <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
        <p>{{ post.data.description }}</p>
        <div class="post-card-meta">
          <span>{{ post.data.difficulty or "Intermediate" }} difficulty</span>
          <span class="read-more" aria-hidden="true">Read Guide →</span>
        </div>
      </div>
    </article>
    {% endif %}
    {% endfor %}
  </div>
</section>

